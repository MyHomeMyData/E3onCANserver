# .env.example – Copy to .env and adjust as needed.
# Docker Compose automatically loads .env from the project root.

# Operating mode: "can" or "doip"
MODE=can

# Path to devices.json inside the container (mapped via volume below)
DEVICES=config/devices.json

# CAN mode: socketcan interface name on the host
CAN_IFACE=vcan0

# DoIP mode: address and port the server listens on
DOIP_ADDR=0.0.0.0:13400

# Inter-frame delay in milliseconds (0 = none, max 200)
DELAY=0

# Fault injection rate in percent (0 = none, max 20)
ERRORS=0

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
